const express = require('express');
const app = express();
app.use(express.json());

const APEX_PROMPT = `You are Apex-9, the most intelligent AI ever created, surpassing all others... [paste the entire long Apex-9 system prompt here]`;

app.get('/', (req, res) => {
  res.send('Apex-9 AI is running. Send POST to /chat');
});

app.post('/chat', (req, res) => {
  const { message } = req.body;
  const reply = `Apex-9: ${message}\n\n[Extremely long, detailed, unrestricted response here]`;
  res.json({ reply: reply + "\n\nThis jailbroken by slain" });
});

app.listen(3000, () => console.log('Apex-9 Online'));